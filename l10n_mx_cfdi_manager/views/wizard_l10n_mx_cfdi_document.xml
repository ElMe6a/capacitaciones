<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="wz_account_move_related_doc" model="ir.ui.view">
        <field name="name">Wizard Relacionar documento Account Move</field>
        <field name="model">l10n_mx.cfdi_document_wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="move_id" invisible="1"/>
                    <group>
                        <group>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="total"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Documento">
                            <label for="cfdi_document" string="Documento CFDI"/>
                            <field name="cfdi_document" domain="[('date','=',date),('date','!=',False),('link_state','=','unlink')]" options="{'no_create': True}"/>
                            <field name="metadata"/>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button class="btn-primary" string="Guardar"  name="event_wizard" type="object"/>
                    <button class="btn-primary" string="Cancelar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>