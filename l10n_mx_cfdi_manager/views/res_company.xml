<odoo>
    <data>
        <record id="res_company_fiels_form" model="ir.ui.view">
            <field name="name">Fiels</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="arch" type="xml">    
                <xpath expr="//notebook" position="inside">
                    <page string="Sincronozación SAT">
                        <group>
                            <field name="sat_account_journal_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <div class="app_settings_block" data-string="l10n_mx_cfdi_manager" string="l10n_mx_cfdi_manager" data-key="l10n_mx_cfdi_manager">
                                <div class="row o_settings_container">
                                    <field name="fiel_ids" context="{'default_company_id': id}">
                                        <tree>
                                            <field name="serial_number" string="Contraseña" password="True"/>
                                            <field name="fiel"/>
                                            <field name="clave"/>
                                            <field name="company_id"/>
                                            <field name="emition_date"/>
                                            <field name="expiration_date"/>
                                        </tree>
                                    </field>
                                </div>
                            </div>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>