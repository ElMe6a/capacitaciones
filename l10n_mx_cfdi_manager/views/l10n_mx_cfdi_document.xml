<odoo>
    <data>
        <record model="ir.ui.view" id="l10n_mx_cfdi_document_form">
            <field name="name">Documento</field>
            <field name="model">l10n_mx.cfdi_document</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="emisor" readonly="1"/>
                                <field name="rfc_emisor" readonly="1"/>
                                <field name="total" readonly="1"/>
                                <field name="link_state" readonly="1" string="¿Esta vinculado?"/>
                            </group>
                            <group>
                                <field name="uuid" readonly="1"/>
                                <field name="cfdi_state" readonly="1"/>
                                <field name="attatch_name" invisible="1"/>
                                <field name="attatch" filename="attatch_name" widget="binary" readonly="1"/><br/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Datos">
                                <field name="metadata_pretty"/>
                            </page>
                            <page string="Facturas">
                                <field name="moves_ids" options="{'create': False}" domain="[('move_type','in',['in_invoice','in_refund','in_receipt'])]"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        
        <record id="view_l10n_mx_cfdi_document_filter" model="ir.ui.view">
            <field name="name">l10n_mx.cfdi_document.search</field>
            <field name="model">l10n_mx.cfdi_document</field>
            <field name="arch" type="xml">
                <search string="Search Journal Items">
                    <group expand="1" string="Group By">
                        <filter string="Estado SAT" name="group_by_state" domain="[]" context="{'group_by': 'cfdi_state'}"/>
                        <filter string="Vinculacion" name="group_by_link" domain="[]" context="{'group_by': 'link_state'}"/>
                        <filter string="Tipo" name="group_by_type" domain="[]" context="{'group_by': 'type_comprobante'}"/>
                    </group>
                </search>
            </field>
        </record>        
        
        <record model="ir.ui.view" id="l10n_mx_cfdi_document_tree">
            <field name="name">Documentos</field>
            <field name="model">l10n_mx.cfdi_document</field>
            <field name="arch" type="xml">
                <tree create="false" edit="false">
                    <field name="uuid" string="UUID"/>
                    <field name="folio" string="Folio"/>
                    <field name="date" string="Fecha"/>
                    <field name="rfc_emisor" string="RFC Emisor"/>
                    <field name="emisor" string="Emisor" optional="hide"/>
                    <field name="total" string="Total" optional="hide"/>
                    <field name="cfdi_state" string="Estado"/>
                    <field name="attatch_name" invisible="1"/>
                    <field name="attatch" filename="attatch_name" widget="binary"/>
                    <field name="cfdi_request"/>
                    <field name="moves_ids" string="Factura" widget="many2many_tags"/>
                    <button name="create_bill" type="object" string="Crear Factura" class="btn btn-primary"/>
                    <button name="verify_state" type="object" string="Verificar Estado" class="btn btn-primary"/>
                </tree>
            </field>
        </record>
    </data>
</odoo>